# ─── Mesaj Paneli — Ortam değişkenleri ─────────────────
# Hızlı kurulum: make setup
# Manuel kurulum: bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

ENV=production
HOST=0.0.0.0
PORT=8000

# ─── Güvenlik (ZORUNLU production) ───────────────────
# make setup otomatik üretir; manuel kurulumda güçlü rastgele değerler kullanın:
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand
BRIDGE_SECRET=CHANGE_ME_generate_with_openssl_rand
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=CHANGE_ME_strong_password_min_8
REQUIRE_PANEL_AUTH=true

# Production: OpenAPI /docs kapalı (açmak için true)
ENABLE_OPENAPI=false

# ─── Test modu — varsayılan KAPALI (mesaj gitmez) ───
# Canlı gönderim için açıkça true yapın:
ALLOW_OUTBOUND_MESSAGES=false

# ─── Telegram (panelden veya buradan) ─────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_TEST_PHONE=

# ─── WhatsApp köprü (Docker'da otomatik) ─────────────
MANAGE_WHATSAPP_BRIDGE=false
WHATSAPP_BRIDGE_URL=http://whatsapp-bridge:3001
WHATSAPP_BRIDGE_PORT=3001
PANEL_URL=http://panel:8000

TIMEZONE=Europe/Istanbul
